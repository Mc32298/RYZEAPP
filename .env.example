# Microsoft OAuth (required for Outlook/Exchange accounts)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://127.0.0.1:42813/auth/microsoft/callback
MICROSOFT_OAUTH_SCOPE=openid profile offline_access User.Read Mail.Read Mail.ReadWrite Mail.Send Calendars.Read

# Google OAuth (required for Gmail accounts)
# Register credentials at https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:53682

# Gemini AI (optional — enables email summarization and AI reply features)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1
